{
  "info": {
    "name": "Prescripciones API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección mínima para el MVP de prescripciones."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login doctor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dr@test.com\",\n  \"password\": \"dr123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/profile"
          }
        }
      ]
    },
    {
      "name": "Prescriptions",
      "item": [
        {
          "name": "List doctor prescriptions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/prescriptions?mine=true&limit=10"
          }
        },
        {
          "name": "Create prescription",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientEmail\": \"patient@test.com\",\n  \"notes\": \"Desde Postman\",\n  \"items\": [\n    {\n      \"name\": \"Ibuprofeno 400mg\",\n      \"dosage\": \"1 cada 8h\",\n      \"quantity\": 10,\n      \"instructions\": \"Con alimentos\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/prescriptions"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/admin/metrics"
          }
        }
      ]
    }
  ]
}
