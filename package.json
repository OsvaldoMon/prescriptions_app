{
  "name": "prescriptions",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "api:dev": "npm run start:dev --workspace=api",
    "web:dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=api && npm run build --workspace=web",
    "test": "npm run test --workspace=api && npm run test --workspace=web",
    "test:e2e": "npm run test:e2e --workspace=api",
    "start:api": "npx prisma migrate deploy && npm run start:prod --workspace=api",
    "db:migrate:deploy": "npx prisma migrate deploy"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "tsx": "^4.20.6"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "prisma": "^6.19.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
